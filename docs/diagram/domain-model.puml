@startuml
title TOEIC Coach AI MVP - Domain Model

left to right direction
skinparam classAttributeIconSize 0

package "User Domain" {
  class User
  class Profile
  class UserStatistic
  class StudySession
}

package "Assessment Domain" {
  class PlacementTest
  class PlacementAnswer
  class PlacementResult

  class Submission
  class SubmissionAnswer
}

package "Question Bank Domain" {
  class Question
  class Choice
  class Audio
  class Transcript
}

package "Classification Domain" {
  class TOEICPart
  class Skill
  class Difficulty
  class GrammarTopic
  class BusinessTopic
}

package "Roadmap Domain" {
  class Roadmap
  class RoadmapItem
}

package "Vocabulary Domain" {
  class Flashcard
  class FlashcardReview
}

package "AI Domain" {
  class AIExplanation
  class AICoachFeedback
}

package "External Systems" {
  class AIService
  class ObjectStorage
}

' =====================
' User relationships
' =====================

User "1" -- "1" Profile
User "1" -- "1" UserStatistic
User "1" -- "*" StudySession

' =====================
' Placement Test
' =====================

User "1" -- "*" PlacementTest
PlacementTest "1" -- "*" PlacementAnswer
PlacementTest "1" -- "1" PlacementResult
PlacementAnswer "*" -- "1" Question

' =====================
' Submission / Practice
' =====================

User "1" -- "*" Submission
Submission "1" -- "*" SubmissionAnswer
SubmissionAnswer "*" -- "1" Question
SubmissionAnswer "*" -- "1" Choice

' =====================
' Question Bank
' =====================

Question "1" -- "*" Choice
Question "*" -- "1" TOEICPart
Question "*" -- "1" Skill
Question "*" -- "1" Difficulty

Question "*" -- "*" GrammarTopic
Question "*" -- "*" BusinessTopic

Question "*" -- "0..1" Audio
Audio "1" -- "0..1" Transcript
Audio ..> ObjectStorage : stored in

' =====================
' Roadmap
' =====================

User "1" -- "1" Roadmap
Roadmap "1" -- "*" RoadmapItem

RoadmapItem "*" -- "0..1" TOEICPart
RoadmapItem "*" -- "0..1" GrammarTopic
RoadmapItem "*" -- "0..1" BusinessTopic
RoadmapItem "*" -- "0..1" Difficulty

' =====================
' Flashcard
' =====================

Flashcard "*" -- "0..1" BusinessTopic
Flashcard "*" -- "0..1" GrammarTopic

User "1" -- "*" FlashcardReview
Flashcard "1" -- "*" FlashcardReview

' =====================
' AI
' =====================

User "1" -- "*" AIExplanation
Question "1" -- "*" AIExplanation
AIExplanation ..> AIService : generated by

User "1" -- "*" AICoachFeedback
AICoachFeedback ..> AIService : generated by

AICoachFeedback ..> UserStatistic : uses
AICoachFeedback ..> Submission : uses recent data

@enduml